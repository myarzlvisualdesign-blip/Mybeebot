<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.myarzl.mybeebot.bot</string>
  <key>WorkingDirectory</key>
  <string>/Users/a1/Mybeebot</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/a1/Mybeebot &amp;&amp; /usr/local/bin/npm run bot:start</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/a1/Mybeebot/logs/bot.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/a1/Mybeebot/logs/bot.err.log</string>
</dict>
</plist>
